{
  "mcpServers": {
    "opnsense": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "OPNSENSE_BASE_URL",
        "-e",
        "OPNSENSE_API_KEY",
        "-e",
        "OPNSENSE_API_SECRET",
        "-e",
        "OPNSENSE_VERIFY_TLS=false",
        "-v",
        "/ABSOLUTE/PATH/TO/private-router-state:/workspace",
        "opnsense-mcp:local"
      ]
    }
  }
}

