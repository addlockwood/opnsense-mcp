# Recommended default. For trusted local lab HTTP only, switch to http://... and set OPNSENSE_ALLOW_INSECURE_HTTP=true.
OPNSENSE_BASE_URL=https://opnsense.internal
OPNSENSE_API_KEY=replace-me
OPNSENSE_API_SECRET=replace-me
OPNSENSE_VERIFY_TLS=true
OPNSENSE_WORKSPACE_PATH=/workspace
OPNSENSE_SNAPSHOT_HOST=this
OPNSENSE_GIT_AUTHOR_NAME=OPNsense MCP
OPNSENSE_GIT_AUTHOR_EMAIL=opnsense-mcp@example.invalid
